{
  "openapi": "3.1.0",
  "info": {
    "title": "LaunchLens Workspace API",
    "version": "2.0.0-platform",
    "description": "Machine-readable workspace snapshot contract for Codex, Supabase, and hackathon collaboration tooling."
  },
  "paths": {
    "/rest/v1/launchlens_workspace": {
      "get": {
        "summary": "Load a LaunchLens workspace snapshot",
        "parameters": [
          {
            "name": "workspace_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "example": "eq.ucws-team-launchlens"
            }
          },
          {
            "name": "select",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "workspace_key,payload,updated_at"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Workspace rows",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WorkspaceRow"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Upsert a LaunchLens workspace snapshot",
        "parameters": [
          {
            "name": "on_conflict",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "workspace_key"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Workspace snapshot saved"
          }
        }
      }
    },
    "/api/graph/overview": {
      "get": {
        "summary": "Return a RepoScape-style overview of the LaunchLens Hub graph",
        "description": "Static LaunchLens exports this structure inside the copied Codex API JSON. A hosted backend can expose the same shape directly.",
        "responses": {
          "200": {
            "description": "Graph overview",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GraphOverview"
                }
              }
            }
          }
        }
      }
    },
    "/api/graph/neighborhood": {
      "get": {
        "summary": "Return a token-budgeted neighborhood around one Hub node",
        "parameters": [
          {
            "name": "node",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "example": "idea-codex-api" }
          },
          {
            "name": "depth",
            "in": "query",
            "schema": { "type": "integer", "minimum": 0, "maximum": 4, "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 80, "default": 24 }
          }
        ],
        "responses": {
          "200": {
            "description": "Neighborhood graph slice",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GraphNeighborhood"
                }
              }
            }
          }
        }
      }
    },
    "/api/agent/bridge": {
      "get": {
        "summary": "Return Codex and ClaudeCodex interoperable graph context",
        "description": "The browser UI currently provides this through Copy Graph Context / Copy Codex Command / Copy Claude Code Command.",
        "responses": {
          "200": {
            "description": "Agent bridge payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentBridge"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "WorkspaceRow": {
        "type": "object",
        "required": ["workspace_key", "payload", "updated_at"],
        "properties": {
          "workspace_key": {
            "type": "string"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "payload": {
            "$ref": "#/components/schemas/LaunchLensWorkspace"
          }
        }
      },
      "LaunchLensWorkspace": {
        "type": "object",
        "required": ["schemaVersion", "project", "platform"],
        "properties": {
          "schemaVersion": {
            "type": "string",
            "example": "2.0.0-platform"
          },
          "project": {
            "type": "object",
            "description": "Project Wall fields and submission metadata."
          },
          "analysis": {
            "type": ["object", "null"],
            "description": "Readiness score, evidence audit, and fix list."
          },
          "platform": {
            "type": "object",
            "properties": {
              "ideas": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Idea"
                }
              },
              "agentRuns": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/AgentRun"
                }
              },
              "tutorialDone": {
                "type": "object"
              },
              "hubFilters": {
                "type": "object"
              },
              "hubNodePositions": {
                "type": "object",
                "description": "Persisted draggable node coordinates keyed by Hub node id."
              },
              "hubViewport": {
                "type": "object",
                "description": "Persisted pan and zoom state for the Hub canvas."
              },
              "hubSearch": {
                "type": "string"
              }
            }
          },
          "generated": {
            "type": ["object", "null"],
            "description": "Generated Markdown outputs."
          },
          "repoScan": {
            "type": ["object", "null"],
            "description": "Public GitHub evidence scan."
          },
          "externalReferences": {
            "type": "array",
            "description": "External projects or methodology references used by this workspace.",
            "items": {
              "$ref": "#/components/schemas/ExternalReference"
            }
          },
          "savedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ExternalReference": {
        "type": "object",
        "required": ["name", "url", "license", "use"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "license": { "type": "string" },
          "use": { "type": "string" }
        }
      },
      "Idea": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "stage": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "parentId": { "type": "string" },
          "relatedIds": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "HubNode": {
        "type": "object",
        "required": ["id", "type", "title"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["project", "process", "idea", "agent", "evidence", "tool"] },
          "title": { "type": "string" },
          "body": { "type": "string" },
          "ready": { "type": "boolean" },
          "degree": { "type": "integer" },
          "x": { "type": "number" },
          "y": { "type": "number" }
        }
      },
      "HubEdge": {
        "type": "object",
        "required": ["from", "to", "type"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "type": { "type": "string", "enum": ["physical", "cognitive", "suspicious", "bridge"] },
          "relation": { "type": "string" }
        }
      },
      "GraphOverview": {
        "type": "object",
        "required": ["nodeCount", "edgeCount", "byType", "edgeTypes", "hubs"],
        "properties": {
          "nodeCount": { "type": "integer" },
          "edgeCount": { "type": "integer" },
          "byType": { "type": "object" },
          "edgeTypes": { "type": "object" },
          "hubs": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/HubNode" }
          }
        }
      },
      "GraphNeighborhood": {
        "type": "object",
        "required": ["root", "depth", "nodes", "edges", "truncated"],
        "properties": {
          "root": { "type": "string" },
          "depth": { "type": "integer" },
          "nodes": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/HubNode" }
          },
          "edges": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/HubEdge" }
          },
          "truncated": { "type": "boolean" }
        }
      },
      "AgentBridge": {
        "type": "object",
        "required": ["kind", "version", "instructions", "graphOverview", "selectedNeighborhood", "workspace", "graph"],
        "properties": {
          "kind": { "type": "string", "example": "launchlens.agent.bridge" },
          "version": { "type": "string" },
          "instructions": { "type": "object" },
          "graphOverview": { "$ref": "#/components/schemas/GraphOverview" },
          "selectedNeighborhood": { "$ref": "#/components/schemas/GraphNeighborhood" },
          "workspace": { "$ref": "#/components/schemas/LaunchLensWorkspace" },
          "graph": {
            "type": "object",
            "properties": {
              "nodes": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/HubNode" }
              },
              "edges": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/HubEdge" }
              }
            }
          }
        }
      },
      "AgentRun": {
        "type": "object",
        "required": ["agentId", "title", "summary", "checklist"],
        "properties": {
          "agentId": { "type": "string" },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "checklist": {
            "type": "array",
            "items": { "type": "string" }
          },
          "linkedIdeas": {
            "type": "array",
            "items": { "type": "string" }
          },
          "generatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
